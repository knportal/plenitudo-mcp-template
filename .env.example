# MCP Server — environment variable template
# Copy to .env and fill in real values. Never commit .env to version control.

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Server config ───────────────────────────────────────────────────────────
DATA_DIR=./data
# FREE_MONTHLY_LIMIT=50
# LOG_FILE=./logs/server.log
# LOG_LEVEL=INFO
# UPGRADE_URL=https://example.com/upgrade

# ── x402 Micropayments (USDC on Base) ──────────────────────────────────────
X402_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
X402_PRICE_USDC=0.001
BASE_RPC_URL=https://mainnet.base.org
